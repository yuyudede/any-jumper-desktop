{
  "name": "any-jumper-desktop",
  "version": "0.1.0",
  "description": "Any Jumper Desktop Electron AI agent app",
  "author": "kancy",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev-electron.mjs",
    "build:main": "esbuild electron/main.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --external:better-sqlite3 --external:node-pty --outfile=dist-electron/main.cjs && esbuild electron/preload.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --outfile=dist-electron/preload.cjs",
    "build:renderer": "vite build",
    "build": "pnpm typecheck && pnpm build:main && pnpm build:renderer",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "pack": "pnpm build && electron-builder --mac --dir",
    "open:app": "open \"release/mac-arm64/Any Jumper Desktop.app\"",
    "preview:app": "pnpm pack && pnpm open:app",
    "dist": "pnpm build && electron-builder"
  },
  "build": {
    "appId": "com.kancy.anyjumper.desktop",
    "productName": "Any Jumper Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icons",
        "to": "icons"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/icons/icon.icns"
    }
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.47",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.6",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deepagents": "^1.10.2",
    "langchain": "^1.4.1",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  }
}
